<?xml version="1.0" encoding="utf-8"?>
<UserControl x:ConnectionId='1'
    x:Class="TestsApplication.Views.Custom_Templates.ShowExistingQuestionsTemplate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root"
    xmlns:local="using:TestsApplication.Views.Custom_Templates"
    xmlns:models="using:TestsApplication.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources >

        
        <DataTemplate x:Key="MultipleChoiceTemplate"                                              >
            <Expander x:ConnectionId='15' HorizontalAlignment="Stretch" Margin="0,5" HorizontalContentAlignment="Stretch" CornerRadius="0"                               >
                <Expander.Header>
                    <StackPanel>
                        <TextBlock x:ConnectionId='16'                        FontSize="16"/>
                        <TextBlock Text="Seleccion Multiple" FontSize="10" Foreground="{StaticResource AccentTextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Expander.Header>

                <StackPanel>
                    <TextBlock x:ConnectionId='17' Height="100"                           Margin="0,10,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <RadioButtons x:ConnectionId='18' IsHitTestVisible="False"                                                             >
                        <RadioButtons.Header>
                            <TextBlock Text="Seleciona la respuesta correcta" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </RadioButtons.Header>
                        <RadioButton x:ConnectionId='21'                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <RadioButton x:ConnectionId='22'                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <RadioButton x:ConnectionId='23'                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <RadioButton x:ConnectionId='24'                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </RadioButtons>
                    <StackPanel HorizontalAlignment="Right" Width="auto" Orientation="Horizontal" Padding="5,0,0,0">
                        <Button x:ConnectionId='19' Content="Editar" Style="{StaticResource AccentButtonStyle}"                                       ClickMode="Press"/>
                        <Button x:ConnectionId='20' Margin="10,0,0,0" Content="Eliminar" Style="{StaticResource SubtleButtonStyle}" ClickMode="Press"                              />
                    </StackPanel>
                </StackPanel>
            </Expander>

        </DataTemplate>

        <DataTemplate x:Key="TrueOrFalseTemplate"                                           >
            <Expander x:ConnectionId='9' HorizontalAlignment="Stretch" Margin="0,5" HorizontalContentAlignment="Stretch" CornerRadius="0"                               >
                <Expander.Header>
                    <StackPanel>
                        <TextBlock Text="Nueva pregunta" FontSize="16" FontStretch="ExtraExpanded"/>
                        <TextBlock Text="Falso y verdadero" FontSize="10" Foreground="Coral"/>
                    </StackPanel>
                </Expander.Header>

                <StackPanel>
                    <TextBlock x:ConnectionId='10'                           Height="100" FontSize="14" Margin="0,10,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <RadioButtons x:ConnectionId='11' IsHitTestVisible="False"                                                     >
                        <RadioButtons.Header>
                            <TextBlock Text="Respuesta correcta" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </RadioButtons.Header>
                        <RadioButton Content="Verdadero" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <RadioButton Content="Falso" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </RadioButtons>
                    <StackPanel HorizontalAlignment="Right" Width="auto" Orientation="Horizontal" Padding="5,0,0,0">
                        <Button x:ConnectionId='12' Content="Editar" Style="{StaticResource AccentButtonStyle}" ClickMode="Press"                                   />
                        <Button x:ConnectionId='13' Margin="10,0,0,0" Content="Eliminar" Style="{StaticResource SubtleButtonStyle}" ClickMode="Press"                              />
                    </StackPanel>
                </StackPanel>
            </Expander>
        </DataTemplate>

        <DataTemplate x:Key="FreeAnswerTemplate"                                           >
            <Expander x:ConnectionId='3' HorizontalAlignment="Stretch" Margin="0,5" HorizontalContentAlignment="Stretch" CornerRadius="0"                               >
                <Expander.Header>
                    <StackPanel>
                        <TextBlock Text="Pendiente de cambiar" FontSize="15"/>
                        <TextBlock Text="Respuesta Libre" FontSize="10" Foreground="Gold"/>
                    </StackPanel>
                </Expander.Header>

                <StackPanel>
                    <TextBlock x:ConnectionId='4' Height="100" Margin="0,10,0,0"                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="Respuesta correcta" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock x:ConnectionId='5'                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <StackPanel HorizontalAlignment="Right" Width="auto" Orientation="Horizontal" Padding="5,0,0,0">
                        <Button x:ConnectionId='6' Content="Editar" Style="{StaticResource AccentButtonStyle}" ClickMode="Press"                                  />
                        <Button x:ConnectionId='7' Margin="10,0,0,0" Content="Eliminar" Style="{StaticResource SubtleButtonStyle}" ClickMode="Press"                              />
                    </StackPanel>
                </StackPanel>
            </Expander>

        </DataTemplate>


        <local:MyDataTemplateSelector x:Key="MyDataTemplateSelector" MultipleChoiceDataTemplate="{StaticResource MultipleChoiceTemplate}" TrueOrFalseDataTemplate="{StaticResource TrueOrFalseTemplate}" FreeAnswerDataTemplate="{StaticResource FreeAnswerTemplate}"/>

    </UserControl.Resources>

    <StackPanel x:ConnectionId='25' x:Name="ExistingQuestionsLayout" Grid.Row="1" Visibility="Visible">
        <ListView x:ConnectionId='26' Margin="0" Padding="0"  SelectionMode="None"                                                    x:Name="ExamQuestionListView"  Height="Auto" HorizontalAlignment="Stretch" ItemTemplateSelector="{StaticResource MyDataTemplateSelector}"/>
        <DropDownButton Margin="10" AutomationProperties.Name="Email" Style="{StaticResource AccentButtonStyle}">
            <DropDownButton.Content>
                <StackPanel Orientation="Horizontal">
                    <FontIcon Glyph="&#xE710;"/>
                    <TextBlock Margin="10,0,0,0" Text="Insertar nueva pregunta"/>
                </StackPanel>
            </DropDownButton.Content>
            <DropDownButton.Flyout>
                <MenuFlyout Placement="Bottom">
                    <MenuFlyoutItem x:ConnectionId='27' Text="Falso y verdadero"                                   >
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE725;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:ConnectionId='28' Text="Seleccion Multiple"                                      >
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8CA;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem x:ConnectionId='29' Text="Respuesta abierta"                                  >
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8C2;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </DropDownButton.Flyout>
        </DropDownButton>
    </StackPanel>
</UserControl>

