<?xml version="1.0" encoding="utf-8"?>
<Page x:ConnectionId='1'
    x:Class="TestsApplication.Views.NewTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TestsApplication.Views"
    xmlns:uControls="using:TestsApplication.Views.Custom_Templates"
    xmlns:Models="using:TestsApplication.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="SectionListDataTemplate"                            >
            <StackPanel x:ConnectionId='3'>
                <TextBlock x:ConnectionId='4'                       />
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="30*"/>
        </Grid.ColumnDefinitions>

        <Grid HorizontalAlignment="Stretch" Margin="10" BorderThickness="0" BorderBrush="DarkSlateGray" CornerRadius="4" Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox x:ConnectionId='9' x:Name="ExamTitle" TextAlignment="Left" BorderThickness="0" Background="Transparent" FontSize="40" HorizontalAlignment="Left"  PlaceholderText="Nuevo examen #1" />
                <TeachingTip x:ConnectionId='10' x:Name="TeachingTipBox" Title="Campo vacio" Subtitle="Debe completar este campo" IsLightDismissEnabled="True">
                    <TeachingTip.IconSource>
                        <SymbolIconSource Symbol="ClearSelection" />
                    </TeachingTip.IconSource>
                </TeachingTip>
                <ComboBox x:ConnectionId='11' x:Name="ComboBoxCategory" Header="Seleccionar categoria" PlaceholderText="Selecciona categoria" Width="200" Grid.Column="1" HorizontalAlignment="Right">
                    <x:String>Medio termino</x:String>
                    <x:String>Examen final</x:String>
                    <x:String>Practica</x:String>
                </ComboBox>
            </Grid>
            <ScrollView Grid.Row="1">
                <ContentControl x:ConnectionId='8' x:Name="DynamicContentControl"  HorizontalContentAlignment="Stretch"/>
            </ScrollView>
        </Grid>

        <StackPanel Grid.Column="1" Width="2" Background="{ThemeResource CardBackgroundFillColorDefault}" Height="Auto" Margin="10"/>

        <Grid Grid.Column="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="90*"/>
                <RowDefinition Height="10*"/>
            </Grid.RowDefinitions>

            <StackPanel BorderBrush="{ThemeResource TextFillColorDisabledBrush}" BorderThickness="0" Padding="5">
                <TextBlock Text="Secciones" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="13"/>
                <ListView x:ConnectionId='7' x:Name="SectionsListView"                                         ItemTemplate="{StaticResource SectionListDataTemplate}" Height="200" SelectionMode="Multiple"/>


            </StackPanel>
            <Grid BorderBrush="{ThemeResource TextFillColorDisabledBrush}" BorderThickness="0" Grid.Row="1" Margin="0 5 0 0" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50*"/>
                    <ColumnDefinition Width="50*"/>
                </Grid.ColumnDefinitions>
                <Button x:ConnectionId='5' x:Name="CreateExamButton" Content="Crear" Style="{StaticResource AccentButtonStyle}"                                HorizontalAlignment="Stretch"/>
                <Button x:ConnectionId='6' Grid.Column="1"  Content="Cancelar" Style="{StaticResource SubtleButtonStyle}"                            HorizontalAlignment="Stretch"/>
            </Grid>

        </Grid>
    </Grid>
</Page>

