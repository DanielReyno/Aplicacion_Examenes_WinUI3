<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="TestsApplication.Views.Custom_Templates.ShowTrueOrFalseQuestionTemplate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TestsApplication.Views.Custom_Templates"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel x:Name="TrueOrFalseQuestionLayout" Grid.Row="1" Visibility="Visible">
        <TextBlock Margin="10" Text="Pregunta #n" FontSize="20"/>
        <RichEditBox x:Name="RichEditBoxContent" PlaceholderText="Insertar Texto" Height="100" AutomationProperties.Name="Insertar"/>
        <RadioButtons x:Name="RadioButtonsOptions" Margin="10" Header="Seleccione la respuesta correcta">
            <RadioButton Content="Verdadero"/>
            <RadioButton Content="False"/>
        </RadioButtons>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="100" Content="Cancelar" Style="{StaticResource SubtleButtonStyle}" Click="CancelExamQuestion"/>
            <Button Width="100" Content="Crear" Style="{StaticResource AccentButtonStyle}" Click="CreateExamQuestion"/>
        </StackPanel>
    </StackPanel>
</UserControl>
