<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="TestsApplication.Views.Custom_Templates.ShowExistingQuestionsTemplate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="Root"
    xmlns:local="using:TestsApplication.Views.Custom_Templates"
    xmlns:models="using:TestsApplication.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources >

        
        <DataTemplate x:Key="MultipleChoiceTemplate" x:DataType="models:PreguntaSeleccionMultiple">
            <Expander HorizontalAlignment="Stretch" Margin="0,5" HorizontalContentAlignment="Stretch" CornerRadius="0" LostFocus="Expander_LostFocus">
                <Expander.Header>
                    <StackPanel>
                        <TextBlock Text="{x:Bind Titulo}" FontSize="16"/>
                        <TextBlock Text="Seleccion Multiple" FontSize="10" Foreground="{StaticResource AccentTextFillColorTertiaryBrush}"/>
                    </StackPanel>
                </Expander.Header>

                <StackPanel>
                    <TextBlock Height="100" Text="{x:Bind Contenido}" Margin="0,10,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <RadioButtons IsHitTestVisible="False" SelectedIndex="{x:Bind Opciones.IndexOf(RespuestaCorrecta)}">
                        <RadioButtons.Header>
                            <TextBlock Text="Seleciona la respuesta correcta" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </RadioButtons.Header>
                        <RadioButton Content="{x:Bind Opciones[0]}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <RadioButton Content="{x:Bind Opciones[1]}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <RadioButton Content="{x:Bind Opciones[2]}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <RadioButton Content="{x:Bind Opciones[3]}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </RadioButtons>
                    <StackPanel HorizontalAlignment="Right" Width="auto" Orientation="Horizontal" Padding="5,0,0,0">
                        <Button Content="Editar" Style="{StaticResource AccentButtonStyle}" Click="MultipleChoiceQuestion_Button" ClickMode="Press"/>
                        <Button Margin="10,0,0,0" Content="Eliminar" Style="{StaticResource SubtleButtonStyle}" ClickMode="Press" Click="DeleteQuestion_Button"/>
                    </StackPanel>
                </StackPanel>
            </Expander>

        </DataTemplate>

        <DataTemplate x:Key="TrueOrFalseTemplate" x:DataType="models:PreguntaFalsoVerdadero">
            <Expander HorizontalAlignment="Stretch" Margin="0,5" HorizontalContentAlignment="Stretch" CornerRadius="0" LostFocus="Expander_LostFocus">
                <Expander.Header>
                    <StackPanel>
                        <TextBlock Text="Nueva pregunta" FontSize="16" FontStretch="ExtraExpanded"/>
                        <TextBlock Text="Falso y verdadero" FontSize="10" Foreground="Coral"/>
                    </StackPanel>
                </Expander.Header>

                <StackPanel>
                    <TextBlock Text="{x:Bind Contenido}" Height="100" FontSize="14" Margin="0,10,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <RadioButtons IsHitTestVisible="False" SelectedIndex="{x:Bind GetRespuestaCorrectaIndex()}">
                        <RadioButtons.Header>
                            <TextBlock Text="Respuesta correcta" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                        </RadioButtons.Header>
                        <RadioButton Content="Verdadero" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <RadioButton Content="Falso" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </RadioButtons>
                    <StackPanel HorizontalAlignment="Right" Width="auto" Orientation="Horizontal" Padding="5,0,0,0">
                        <Button Content="Editar" Style="{StaticResource AccentButtonStyle}" ClickMode="Press" Click="TrueOrFalseQuestion_Button"/>
                        <Button Margin="10,0,0,0" Content="Eliminar" Style="{StaticResource SubtleButtonStyle}" ClickMode="Press" Click="DeleteQuestion_Button"/>
                    </StackPanel>
                </StackPanel>
            </Expander>
        </DataTemplate>

        <DataTemplate x:Key="FreeAnswerTemplate" x:DataType="models:PreguntaRespuestaLibre">
            <Expander HorizontalAlignment="Stretch" Margin="0,5" HorizontalContentAlignment="Stretch" CornerRadius="0" LostFocus="Expander_LostFocus">
                <Expander.Header>
                    <StackPanel>
                        <TextBlock Text="Pendiente de cambiar" FontSize="15"/>
                        <TextBlock Text="Respuesta Libre" FontSize="10" Foreground="Gold"/>
                    </StackPanel>
                </Expander.Header>

                <StackPanel>
                    <TextBlock Height="100" Margin="0,10,0,0" Text="{x:Bind Contenido}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock Text="Respuesta correcta" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock Text="{x:Bind RespuestaCorrecta}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <StackPanel HorizontalAlignment="Right" Width="auto" Orientation="Horizontal" Padding="5,0,0,0">
                        <Button Content="Editar" Style="{StaticResource AccentButtonStyle}" ClickMode="Press" Click="FreeAnswerQuestion_Button"/>
                        <Button Margin="10,0,0,0" Content="Eliminar" Style="{StaticResource SubtleButtonStyle}" ClickMode="Press" Click="DeleteQuestion_Button"/>
                    </StackPanel>
                </StackPanel>
            </Expander>

        </DataTemplate>


        <local:MyDataTemplateSelector x:Key="MyDataTemplateSelector" MultipleChoiceDataTemplate="{StaticResource MultipleChoiceTemplate}" TrueOrFalseDataTemplate="{StaticResource TrueOrFalseTemplate}" FreeAnswerDataTemplate="{StaticResource FreeAnswerTemplate}"/>

    </UserControl.Resources>

    <StackPanel x:Name="ExistingQuestionsLayout" Grid.Row="1" Visibility="Visible">
        <ListView Margin="0" Padding="0"  SelectionMode="None" ItemsSource="{x:Bind PreguntasTemp, Mode=TwoWay}"  x:Name="ExamQuestionListView"  Height="Auto" HorizontalAlignment="Stretch" ItemTemplateSelector="{StaticResource MyDataTemplateSelector}"/>
        <DropDownButton Margin="10" AutomationProperties.Name="Email" Style="{StaticResource AccentButtonStyle}">
            <DropDownButton.Content>
                <StackPanel Orientation="Horizontal">
                    <FontIcon Glyph="&#xE710;"/>
                    <TextBlock Margin="10,0,0,0" Text="Insertar nueva pregunta"/>
                </StackPanel>
            </DropDownButton.Content>
            <DropDownButton.Flyout>
                <MenuFlyout Placement="Bottom">
                    <MenuFlyoutItem Text="Falso y verdadero" Click="TrueOrFalseQuestion_Button">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE725;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Seleccion Multiple" Click="MultipleChoiceQuestion_Button">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8CA;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Respuesta abierta" Click="FreeAnswerQuestion_Button">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8C2;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </DropDownButton.Flyout>
        </DropDownButton>
    </StackPanel>
</UserControl>
